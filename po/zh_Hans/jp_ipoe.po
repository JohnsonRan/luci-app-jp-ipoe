msgid "Apply or remove IPoE configuration immediately."
msgstr "立即应用或移除 IPoE 配置。"

#: htdocs/luci-static/resources/view/jp_ipoe/config.js:135
msgid ""
"Applying IPoE configuration. Please wait ~30 seconds for IPv6 prefix "
"detection."
msgstr "应用 IPoE 配置中，请等待最多30秒来获取 IPv6 前缀"

