#!/bin/sh

. /lib/functions.sh

JP_IPOE_STATE_DIR="${JP_IPOE_STATE_DIR:-/etc/jp-ipoe-state}"

jp_ipoe_state_ensure_dir() {
	[ -d "$JP_IPOE_STATE_DIR" ] || mkdir -p "$JP_IPOE_STATE_DIR"
}

jp_ipoe_state_file() {
	local safe_name

	safe_name="$(printf '%s' "$1" | tr -c 'A-Za-z0-9_.-' '_')"
	printf '%s/%s.state' "$JP_IPOE_STATE_DIR" "$safe_name"
}

jp_ipoe_state_quote_value() {
	printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

jp_ipoe_state_write_var() {
	local file="$1"
	local key="$2"
	local value="$3"

	printf '%s=%s\n' "$key" "$(jp_ipoe_state_quote_value "$value")" >> "$file"
}

jp_ipoe_uci_set_or_delete_option() {
	local package="$1"
	local section="$2"
	local option="$3"
	local value="$4"

	if [ -n "$value" ]; then
		uci set "$package.$section.$option=$value"
	else
		uci delete "$package.$section.$option" 2>/dev/null || true
	fi
}

jp_ipoe_state_snapshot_uci_section() {
	local package="$1"
	local section="$2"
	local state_id="$3"
	shift 3

	local file
	local section_type
	local option
	local value

	file="$(jp_ipoe_state_file "$state_id")"
	[ -f "$file" ] && return 0

	jp_ipoe_state_ensure_dir
	: > "$file"

	section_type="$(uci -q get "$package.$section" 2>/dev/null)"
	if [ -n "$section_type" ]; then
		jp_ipoe_state_write_var "$file" "SECTION_EXISTS" "1"
		jp_ipoe_state_write_var "$file" "SECTION_TYPE" "$section_type"
	else
		jp_ipoe_state_write_var "$file" "SECTION_EXISTS" "0"
		jp_ipoe_state_write_var "$file" "SECTION_TYPE" ""
	fi

	for option in "$@"; do
		if value="$(uci -q get "$package.$section.$option" 2>/dev/null)"; then
			jp_ipoe_state_write_var "$file" "${option}_SET" "1"
			jp_ipoe_state_write_var "$file" "${option}_VALUE" "$value"
		else
			jp_ipoe_state_write_var "$file" "${option}_SET" "0"
			jp_ipoe_state_write_var "$file" "${option}_VALUE" ""
		fi
	done
}

jp_ipoe_state_restore_uci_section() {
	local package="$1"
	local section="$2"
	local state_id="$3"
	shift 3

	local file
	local option
	local option_set
	local option_value
	local current_type

	file="$(jp_ipoe_state_file "$state_id")"
	[ -f "$file" ] || return 0
	. "$file"

	if [ "$SECTION_EXISTS" != "1" ]; then
		uci delete "$package.$section" 2>/dev/null || true
		return 0
	fi

	current_type="$(uci -q get "$package.$section" 2>/dev/null)"
	[ "$current_type" = "$SECTION_TYPE" ] || uci set "$package.$section=$SECTION_TYPE"

	for option in "$@"; do
		eval "option_set=\${${option}_SET:-0}"
		if [ "$option_set" = "1" ]; then
			eval "option_value=\${${option}_VALUE}"
			uci set "$package.$section.$option=$option_value"
		else
			uci delete "$package.$section.$option" 2>/dev/null || true
		fi
	done
}

jp_ipoe_state_snapshot_firewall_zone_networks() {
	local zone="$1"
	local file
	local value

	file="$(jp_ipoe_state_file firewall_zone_networks)"
	[ -f "$file" ] && return 0

	jp_ipoe_state_ensure_dir
	: > "$file"
	jp_ipoe_state_write_var "$file" "ZONE" "$zone"
	if value="$(uci -q get firewall."$zone".network 2>/dev/null)"; then
		jp_ipoe_state_write_var "$file" "NETWORK_SET" "1"
		jp_ipoe_state_write_var "$file" "NETWORK_VALUE" "$value"
	else
		jp_ipoe_state_write_var "$file" "NETWORK_SET" "0"
		jp_ipoe_state_write_var "$file" "NETWORK_VALUE" ""
	fi
}

jp_ipoe_state_restore_firewall_zone_networks() {
	local file
	local net

	file="$(jp_ipoe_state_file firewall_zone_networks)"
	[ -f "$file" ] || return 0
	. "$file"

	[ -n "$ZONE" ] || return 0
	uci delete firewall."$ZONE".network 2>/dev/null || true

	if [ "$NETWORK_SET" = "1" ]; then
		for net in $NETWORK_VALUE; do
			uci add_list firewall."$ZONE".network="$net"
		done
	fi
}

jp_ipoe_state_clear() {
	rm -rf "$JP_IPOE_STATE_DIR"
}

jp_ipoe_state_record_pppoe_sections() {
	local sections="$1"
	local file

	file="$(jp_ipoe_state_file pppoe_sections)"
	jp_ipoe_state_ensure_dir
	: > "$file"
	jp_ipoe_state_write_var "$file" "SECTIONS" "$sections"
}

jp_ipoe_state_load_pppoe_sections() {
	local file

	file="$(jp_ipoe_state_file pppoe_sections)"
	[ -f "$file" ] || return 1
	. "$file"
	printf '%s' "$SECTIONS"
}

jp_ipoe_state_snapshot_session_metadata() {
	local file
	local wan6_iface="$1"
	local mape_iface="$2"

	file="$(jp_ipoe_state_file session)"
	jp_ipoe_state_ensure_dir
	: > "$file"
	jp_ipoe_state_write_var "$file" "WAN6_IFACE" "$wan6_iface"
	jp_ipoe_state_write_var "$file" "MAPE_IFACE" "$mape_iface"
}

jp_ipoe_state_load_session_metadata() {
	local file

	JP_IPOE_SESSION_WAN6_IFACE=""
	JP_IPOE_SESSION_MAPE_IFACE=""

	file="$(jp_ipoe_state_file session)"
	[ -f "$file" ] || return 1
	. "$file"
	JP_IPOE_SESSION_WAN6_IFACE="$WAN6_IFACE"
	JP_IPOE_SESSION_MAPE_IFACE="$MAPE_IFACE"
	return 0
}
