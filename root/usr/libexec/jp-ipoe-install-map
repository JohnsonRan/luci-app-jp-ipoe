#!/bin/sh

ROOT="${IPKG_INSTROOT:-}"
TARGET="$ROOT/lib/netifd/proto/map.sh"
BACKUP="$ROOT/lib/netifd/proto/map.sh.orig"
SOURCE="$ROOT/usr/share/jp-ipoe/map.sh"
TARGET_DIR="${TARGET%/*}"

[ -f "$SOURCE" ] || {
	echo "ERROR: Patched map.sh not found at $SOURCE" >&2
	exit 1
}

[ -d "$TARGET_DIR" ] || mkdir -p "$TARGET_DIR"

if [ -f "$TARGET" ] && ! grep -q "JP_IPOE_PATCH_VERSION=" "$TARGET" 2>/dev/null; then
	cp "$TARGET" "$BACKUP" || exit 1
fi

cp -f "$SOURCE" "$TARGET" || exit 1
chmod +x "$TARGET" || exit 1
