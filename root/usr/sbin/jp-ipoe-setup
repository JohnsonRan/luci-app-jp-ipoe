#!/bin/sh
#
# jp-ipoe-setup - OCN Virtual Connect (MAP-E) auto-configuration script
# For OpenWrt 22.03+ (fw4/nftables)
#
# Usage:
#   jp-ipoe-setup start   - Configure IPoE interfaces
#   jp-ipoe-setup stop    - Remove IPoE interfaces
#   jp-ipoe-setup status  - Print current status as JSON
#   jp-ipoe-setup detect_br - Attempt to detect BR address
#

. /lib/functions.sh
. /usr/share/jp-ipoe/config.sh
. /usr/libexec/jp-ipoe-state

LOG_TAG="jp-ipoe"
PPPOE_FALLBACK_METRIC="200"
JP_IPOE_INFO_HELPER="/usr/libexec/jp-ipoe-info"

log() {
	logger -t "$LOG_TAG" "$@"
	echo "$@" >&2
}

log_err() {
	logger -t "$LOG_TAG" -p daemon.err "$@"
	echo "ERROR: $@" >&2
}

resolve_restore_targets() {
	RESTORE_WAN6_IFACE="$WAN6_IFACE"
	RESTORE_MAPE_IFACE="$MAPE_IFACE"

	if jp_ipoe_state_load_session_metadata; then
		[ -n "$JP_IPOE_SESSION_WAN6_IFACE" ] && RESTORE_WAN6_IFACE="$JP_IPOE_SESSION_WAN6_IFACE"
		[ -n "$JP_IPOE_SESSION_MAPE_IFACE" ] && RESTORE_MAPE_IFACE="$JP_IPOE_SESSION_MAPE_IFACE"
	fi
}

FIREWALL_ZONE_MATCH=""
PPPOE_SECTION_MATCHES=""
NETWORK_DEVICE_MATCH=""

firewall_zone_find_by_name_cb() {
	local section="$1"
	local target_name="$2"
	local section_name

	[ -n "$FIREWALL_ZONE_MATCH" ] && return 0
	config_get section_name "$section" name ""
	[ "$section_name" = "$target_name" ] && FIREWALL_ZONE_MATCH="$section"
}

firewall_zone_find_by_network_cb() {
	local section="$1"
	local target_network="$2"
	local networks
	local net

	[ -n "$FIREWALL_ZONE_MATCH" ] && return 0
	config_get networks "$section" network ""
	for net in $networks; do
		if [ "$net" = "$target_network" ]; then
			FIREWALL_ZONE_MATCH="$section"
			return 0
		fi
	done
}

find_firewall_zone() {
	local target_name="${1:-wan}"
	local primary_network="$2"
	local secondary_network="$3"

	config_load firewall

	FIREWALL_ZONE_MATCH=""
	config_foreach firewall_zone_find_by_name_cb zone "$target_name"
	[ -n "$FIREWALL_ZONE_MATCH" ] && {
		printf '%s' "$FIREWALL_ZONE_MATCH"
		return 0
	}

	if [ -n "$primary_network" ]; then
		FIREWALL_ZONE_MATCH=""
		config_foreach firewall_zone_find_by_network_cb zone "$primary_network"
		[ -n "$FIREWALL_ZONE_MATCH" ] && {
			printf '%s' "$FIREWALL_ZONE_MATCH"
			return 0
		}
	fi

	if [ -n "$secondary_network" ]; then
		FIREWALL_ZONE_MATCH=""
		config_foreach firewall_zone_find_by_network_cb zone "$secondary_network"
		[ -n "$FIREWALL_ZONE_MATCH" ] && {
			printf '%s' "$FIREWALL_ZONE_MATCH"
			return 0
		}
	fi

	return 1
}

get_firewall_zone_networks() {
	local zone="$1"
	local networks

	config_load firewall
	config_get networks "$zone" network ""
	printf '%s' "$networks"
}

pppoe_section_collect_cb() {
	local section="$1"
	local proto

	config_get proto "$section" proto ""
	[ "$proto" = "pppoe" ] || return 0
	PPPOE_SECTION_MATCHES="${PPPOE_SECTION_MATCHES}${PPPOE_SECTION_MATCHES:+ }$section"
}

find_pppoe_sections() {
	config_load network
	PPPOE_SECTION_MATCHES=""
	config_foreach pppoe_section_collect_cb interface
	printf '%s' "$PPPOE_SECTION_MATCHES"
}

network_device_find_by_name_cb() {
	local section="$1"
	local target_name="$2"
	local name

	[ -n "$NETWORK_DEVICE_MATCH" ] && return 0
	config_get name "$section" name ""
	[ "$name" = "$target_name" ] && NETWORK_DEVICE_MATCH="$section"
}

find_network_device_section() {
	local target_name="$1"

	[ -n "$target_name" ] || return 1
	config_load network

	NETWORK_DEVICE_MATCH=""
	config_foreach network_device_find_by_name_cb device "$target_name"
	[ -n "$NETWORK_DEVICE_MATCH" ] || return 1

	printf '%s' "$NETWORK_DEVICE_MATCH"
}

list_has_item() {
	local list="$1"
	local item="$2"
	local entry

	for entry in $list; do
		[ "$entry" = "$item" ] && return 0
	done

	return 1
}

# Wait for WAN6 to get an IPv6 address (with timeout)
wait_for_ipv6() {
	local iface="$1"
	local timeout="${2:-60}"
	local elapsed=0

	log "Waiting for IPv6 address on $iface (timeout ${timeout}s)..."
	while [ $elapsed -lt $timeout ]; do
		local ip6=$(ip -6 addr show dev "$iface" scope global 2>/dev/null | \
			awk '/inet6/ && !/::1/ {print $2; exit}')
		if [ -n "$ip6" ]; then
			log "Got IPv6 address: $ip6"
			echo "$ip6"
			return 0
		fi
		sleep 2
		elapsed=$((elapsed + 2))
	done
	log_err "Timeout waiting for IPv6 address on $iface"
	return 1
}

# Get IPv6 prefix from WAN6 interface
get_ipv6_prefix() {
	local iface="$1"
	local p64
	local ip6

	# Prefer the kernel-installed connected /64 route instead of slicing text out of
	# a possibly compressed IPv6 address representation.
	p64=$(ip -6 route show dev "$iface" proto kernel 2>/dev/null | \
		awk '$1 ~ /\/64$/ && $1 !~ /^fe80:/ { print $1; exit }')
	if [ -n "$p64" ]; then
		log "IPv6 /64 prefix from kernel route: $p64"
		echo "$p64"
		return 0
	fi

	ip6=$(ip -6 addr show dev "$iface" scope global 2>/dev/null | \
		awk '/inet6/ && !/::1/ {print $2; exit}')
	if [ -z "$ip6" ]; then
		log_err "No global IPv6 address found on $iface"
		return 1
	fi

	p64=$(printf '%s\n' "$ip6" | awk '
		{
			sub(/\/.*/, "", $0)
			if ($0 ~ /::/) {
				split($0, halves, "::")
				left_count = (halves[1] == "" ? 0 : split(halves[1], left, ":"))
				right_count = (halves[2] == "" ? 0 : split(halves[2], right, ":"))
				total = 0
				for (i = 1; i <= left_count; i++)
					parts[++total] = left[i]
				zeros = 8 - left_count - right_count
				for (i = 1; i <= zeros; i++)
					parts[++total] = "0"
				for (i = 1; i <= right_count; i++)
					parts[++total] = right[i]
			} else {
				total = split($0, parts, ":")
			}

			if (total < 4)
				exit 1

			printf "%s:%s:%s:%s::/64\n",
				(parts[1] == "" ? "0" : parts[1]),
				(parts[2] == "" ? "0" : parts[2]),
				(parts[3] == "" ? "0" : parts[3]),
				(parts[4] == "" ? "0" : parts[4])
		}')
	if [ -z "$p64" ]; then
		log_err "Failed to calculate IPv6 /64 prefix from $ip6"
		return 1
	fi

	log "IPv6 /64 prefix from address fallback: $p64"
	echo "$p64"
	return 0
}

ensure_wan_device_ipv6() {
	local device="$1"
	local section

	section="$(find_network_device_section "$device")" || {
		log "No explicit network device section found for $device; leaving device IPv6 setting unchanged."
		return 0
	}

	jp_ipoe_state_snapshot_uci_section network "$section" "network_device_${section}" name ipv6
	uci set network."$section".ipv6="1"
	log "Enabled IPv6 on device $device."
}

# MAP-E still needs wan6.ip6prefix when relay mode is enabled or when the
# tunnel is being driven by manual MAP bounds / BR settings.
wan6_ip6prefix_required() {
	[ "$DHCPV6_RELAY" = "1" ] && return 0
	[ -n "$IPADDR" ] && return 0
	[ -n "$IP6PREFIX" ] && return 0
	[ -n "$BR_ADDR" ] && return 0
	return 1
}

ensure_wan6_ip6prefix() {
	local wan6_iface="$1"
	local wan6_dev="$2"
	local ip6prefix
	local current_prefix

	if ! wan6_ip6prefix_required; then
		log "Leaving $wan6_iface ip6prefix unchanged; MAP-E is using automatic PD matching."
		return 0
	fi

	ip6prefix=$(get_ipv6_prefix "$wan6_dev") || return 1
	[ -n "$ip6prefix" ] || return 1

	current_prefix=$(uci -q get network."$wan6_iface".ip6prefix 2>/dev/null)
	if [ "$current_prefix" = "$ip6prefix" ]; then
		log "$wan6_iface ip6prefix already set to $ip6prefix"
		return 0
	fi

	log "Setting $wan6_iface ip6prefix to $ip6prefix for MAP-E startup"
	uci set network."$wan6_iface".ip6prefix="$ip6prefix"
	uci commit network
	ifdown "$wan6_iface" 2>/dev/null || true
	sleep 2
	ifup "$wan6_iface" 2>/dev/null || true
	wait_for_ipv6 "$wan6_dev" 60 >/dev/null || return 1
}

# Configure WAN6 interface via UCI
setup_wan6() {
	local device="$1"
	local iface="$2"
	local ip6prefix="$3"

	log "Configuring $iface (DHCPv6) on device $device..."
	jp_ipoe_state_snapshot_uci_section network "$iface" "network_${iface}" \
		device proto reqaddress reqprefix ip6assign ip6prefix

	# Check if iface already exists
	local exists=$(uci -q get network."$iface" 2>/dev/null)
	if [ -z "$exists" ]; then
		uci set network."$iface"=interface
	fi

	uci set network."$iface".device="$device"
	uci set network."$iface".proto=dhcpv6
	uci set network."$iface".reqaddress=try
	uci set network."$iface".reqprefix=auto
	uci set network."$iface".ip6assign='64'

	# Set ip6prefix to force /64 (needed when ISP doesn't provide PD)
	jp_ipoe_uci_set_or_delete_option network "$iface" ip6prefix "$ip6prefix"

	uci commit network
	log "WAN6 interface $iface configured"
}

resolve_br_addr() {
	local wan6_iface="$1"
	local br_addr="$2"
	local legacymap="$3"
	local rule_data

	if [ -n "$br_addr" ]; then
		printf '%s' "$br_addr"
		return 0
	fi

	log "BR address not set, trying to detect via mapcalc..."
	rule_data=$(LEGACY="$legacymap" mapcalc "$wan6_iface" "type=map-e" 2>/dev/null)
	if [ $? -eq 0 ] && [ -n "$rule_data" ]; then
		br_addr="$(sh "$JP_IPOE_INFO_HELPER" lookup_br "$wan6_iface" "$legacymap" 2>/dev/null)"
		if [ -n "$br_addr" ]; then
			log "Detected BR address: $br_addr"
			printf '%s' "$br_addr"
			return 0
		fi
	fi

	log_err "BR address is empty. OCN Virtual Connect requires manual parameters if PD DHCP is disabled."
	log_err "Please use the map-e calculator (http://ipv4.web.fc2.com/map-e.html) and fill in the BR Address and other parameters in LuCI."
	return 1
}

# Configure MAP-E interface via UCI
setup_mape() {
	local mape_iface="$1"
	local wan6_iface="$2"
	local br_addr="$3"
	local legacymap="$4"

	log "Configuring MAP-E interface $mape_iface..."
	jp_ipoe_state_snapshot_uci_section network "$mape_iface" "network_${mape_iface}" \
		proto maptype peeraddr tunlink encaplimit legacymap ipaddr \
		ip4prefixlen ip6prefix ip6prefixlen ealen psidlen offset

	br_addr="$(resolve_br_addr "$wan6_iface" "$br_addr" "$legacymap")" || return 1

	# Create/update MAP-E interface
	local exists=$(uci -q get network."$mape_iface" 2>/dev/null)
	if [ -z "$exists" ]; then
		uci set network."$mape_iface"=interface
	fi

	uci set network."$mape_iface".proto=map
	uci set network."$mape_iface".maptype=map-e
	uci set network."$mape_iface".peeraddr="$br_addr"
	uci set network."$mape_iface".tunlink="$wan6_iface"
	uci set network."$mape_iface".encaplimit=ignore
	if [ "$legacymap" = "1" ]; then
		uci set network."$mape_iface".legacymap=1
	else
		uci delete network."$mape_iface".legacymap 2>/dev/null || true
	fi

	# Populate advanced manual MAP-E bounds if set
	jp_ipoe_uci_set_or_delete_option network "$mape_iface" ipaddr "$IPADDR"
	jp_ipoe_uci_set_or_delete_option network "$mape_iface" ip4prefixlen "$IP4PREFIXLEN"
	jp_ipoe_uci_set_or_delete_option network "$mape_iface" ip6prefix "$IP6PREFIX"
	jp_ipoe_uci_set_or_delete_option network "$mape_iface" ip6prefixlen "$IP6PREFIXLEN"
	jp_ipoe_uci_set_or_delete_option network "$mape_iface" ealen "$EALEN"
	jp_ipoe_uci_set_or_delete_option network "$mape_iface" psidlen "$PSIDLEN"
	jp_ipoe_uci_set_or_delete_option network "$mape_iface" offset "$OFFSET"

	uci commit network
	log "MAP-E interface $mape_iface configured with BR $br_addr"
}

setup_pppoe_fallback_metrics() {
	local sections
	local section
	local wan_zone
	local wan_zone_networks
	local sections_to_update

	sections="$(find_pppoe_sections)"
	[ -n "$sections" ] || return 0
	wan_zone="$(find_firewall_zone "wan" "$WAN6_IFACE" "wan")"
	[ -n "$wan_zone" ] && wan_zone_networks="$(get_firewall_zone_networks "$wan_zone")"

	sections_to_update=""
	for section in $sections; do
		if [ -n "$wan_zone_networks" ]; then
			list_has_item "$wan_zone_networks" "$section" || continue
		else
			case "$section" in
				wan|pppoe-wan) ;;
				*) continue ;;
			esac
		fi
		sections_to_update="${sections_to_update}${sections_to_update:+ }$section"
	done

	[ -n "$sections_to_update" ] || return 0
	jp_ipoe_state_record_pppoe_sections "$sections_to_update"

	for section in $sections_to_update; do
		jp_ipoe_state_snapshot_uci_section network "$section" "network_${section}" metric
		uci set network."$section".metric="$PPPOE_FALLBACK_METRIC"
		log "Set PPPoE fallback metric $PPPOE_FALLBACK_METRIC on $section"
	done

	uci commit network
}

# Add interfaces to WAN firewall zone
setup_firewall() {
	local wan6_iface="$1"
	local mape_iface="$2"
	local wan_zone

	log "Configuring firewall zones..."

	wan_zone="$(find_firewall_zone "wan" "$wan6_iface" "wan")"

	if [ -z "$wan_zone" ]; then
		log_err "Could not find WAN firewall zone"
		return 1
	fi

	jp_ipoe_state_snapshot_firewall_zone_networks "$wan_zone"

	# Add wan6 and mape to WAN zone if not already there
	for iface in "$wan6_iface" "$mape_iface"; do
		local already_in_zone=0
		local net
		for net in $(uci -q get firewall."$wan_zone".network 2>/dev/null); do
			[ "$net" = "$iface" ] && already_in_zone=1
		done
		if [ "$already_in_zone" = "0" ]; then
			uci add_list firewall."$wan_zone".network="$iface"
			log "Added $iface to WAN firewall zone"
		else
			log "$iface already in WAN firewall zone"
		fi
	done

	uci commit firewall
}

# Install the patched map.sh
install_map_sh() {
	local our_map="/lib/netifd/proto/map.sh"
	local backup="/lib/netifd/proto/map.sh.orig"
	local patched_src="/usr/share/jp-ipoe/map.sh"
	local helper="/usr/libexec/jp-ipoe-map-nft"
	local state_helper="/usr/libexec/jp-ipoe-state"
	local info_helper="/usr/libexec/jp-ipoe-info"

	if [ ! -f "$helper" ]; then
		log_err "Required MAP-E nft helper not found at $helper"
		return 1
	fi

	if [ ! -f "$state_helper" ]; then
		log_err "Required state helper not found at $state_helper"
		return 1
	fi

	if [ ! -f "$info_helper" ]; then
		log_err "Required info helper not found at $info_helper"
		return 1
	fi

	if [ -f "$our_map" ]; then
		# Backup original only if it is not already our managed version.
		if ! grep -q "JP_IPOE_PATCH_VERSION=" "$our_map" 2>/dev/null; then
			cp "$our_map" "$backup"
			log "Backed up original map.sh to $backup"
		fi
	fi

	if [ -f "$patched_src" ]; then
		if cmp -s "$patched_src" "$our_map" 2>/dev/null; then
			log "Patched map.sh already installed"
		else
			cp -f "$patched_src" "$our_map"
			chmod +x "$our_map"
			log "Installed optimized patched map.sh (per-interface nftables multi-port SNAT)"
		fi
	else
		log_err "Patched map.sh not found at $patched_src"
		return 1
	fi
}

restore_map_sh() {
	local our_map="/lib/netifd/proto/map.sh"
	local backup="/lib/netifd/proto/map.sh.orig"

	[ -f "$backup" ] || return 0
	grep -q "JP_IPOE_PATCH_VERSION=" "$our_map" 2>/dev/null || return 0

	cp -f "$backup" "$our_map"
	chmod +x "$our_map"
	log "Restored original map.sh from $backup"
}

# Configure DHCPv6 / Router Advertisement Relay
configure_dhcpv6_relay() {
	local wan6_iface="$1"
	local enabled="$2"

	if [ "$enabled" = "1" ]; then
		log "Configuring DHCPv6 / RA Relay for $wan6_iface and lan..."
	else
		log "DHCPv6 Relay disabled, restoring standard server mode for lan..."
	fi

	jp_ipoe_state_snapshot_uci_section dhcp "$wan6_iface" "dhcp_${wan6_iface}" interface master ra dhcpv6 ndp ndproxy_routing
	jp_ipoe_state_snapshot_uci_section dhcp "lan" "dhcp_lan" master ra dhcpv6 ndp

	# Ensure dhcp.wan6 exists
	local wan6_dhcp=$(uci -q get dhcp."$wan6_iface" 2>/dev/null)
	if [ -z "$wan6_dhcp" ]; then
		uci set dhcp."$wan6_iface"=dhcp
		uci set dhcp."$wan6_iface".interface="$wan6_iface"
	fi

	if [ "$enabled" = "1" ]; then
		uci set dhcp."$wan6_iface".master="1"
		uci set dhcp."$wan6_iface".ra="relay"
		uci set dhcp."$wan6_iface".dhcpv6="relay"
		uci set dhcp."$wan6_iface".ndp="relay"
		uci set dhcp."$wan6_iface".ndproxy_routing="1"
	else
		uci delete dhcp."$wan6_iface".master 2>/dev/null
		uci set dhcp."$wan6_iface".ra="disabled"
		uci set dhcp."$wan6_iface".dhcpv6="disabled"
		uci set dhcp."$wan6_iface".ndp="disabled"
		uci delete dhcp."$wan6_iface".ndproxy_routing 2>/dev/null
	fi

	local lan_dhcp=$(uci -q get dhcp.lan 2>/dev/null)
	if [ -n "$lan_dhcp" ]; then
		if [ "$enabled" = "1" ]; then
			uci delete dhcp.lan.master 2>/dev/null
			uci set dhcp.lan.ra="relay"
			uci set dhcp.lan.dhcpv6="relay"
			uci set dhcp.lan.ndp="relay"
		else
			uci set dhcp.lan.ra="server"
			uci set dhcp.lan.dhcpv6="server"
			uci delete dhcp.lan.ndp 2>/dev/null
		fi
	fi

	uci commit dhcp
	/etc/init.d/odhcpd restart 2>/dev/null || true
	[ "$enabled" = "1" ] && log "DHCPv6 Relay configured successfully."
}

restore_network_config() {
	local wan6_iface="$1"
	local mape_iface="$2"
	local wan_device="$3"
	local device_section

	jp_ipoe_state_restore_uci_section network "$mape_iface" "network_${mape_iface}" \
		proto maptype peeraddr tunlink encaplimit legacymap ipaddr \
		ip4prefixlen ip6prefix ip6prefixlen ealen psidlen offset
	jp_ipoe_state_restore_uci_section network "$wan6_iface" "network_${wan6_iface}" \
		device proto reqaddress reqprefix ip6assign ip6prefix
	if device_section="$(find_network_device_section "$wan_device")"; then
		jp_ipoe_state_restore_uci_section network "$device_section" "network_device_${device_section}" name ipv6
	fi
	uci commit network
}

restore_pppoe_fallback_metrics() {
	local sections
	local section

	sections="$(jp_ipoe_state_load_pppoe_sections)" || return 0

	for section in $sections; do
		jp_ipoe_state_restore_uci_section network "$section" "network_${section}" metric
	done

	uci commit network
}

restore_dhcp_config() {
	local wan6_iface="$1"

	jp_ipoe_state_restore_uci_section dhcp "$wan6_iface" "dhcp_${wan6_iface}" interface master ra dhcpv6 ndp ndproxy_routing
	jp_ipoe_state_restore_uci_section dhcp "lan" "dhcp_lan" master ra dhcpv6 ndp
	uci commit dhcp
	/etc/init.d/odhcpd restart 2>/dev/null || true
}

restore_firewall_config() {
	jp_ipoe_state_restore_firewall_zone_networks
	uci commit firewall
	fw4 reload 2>/dev/null || true
}

rollback_failed_start() {
	log_err "Start failed, restoring previous configuration."
	resolve_restore_targets
	ifdown "$RESTORE_MAPE_IFACE" 2>/dev/null || true
	ifdown "$RESTORE_WAN6_IFACE" 2>/dev/null || true
	restore_network_config "$RESTORE_WAN6_IFACE" "$RESTORE_MAPE_IFACE" "$WAN_DEVICE"
	restore_pppoe_fallback_metrics
	restore_dhcp_config "$RESTORE_WAN6_IFACE"
	restore_firewall_config
	restore_map_sh
	jp_ipoe_state_clear
}

fail_start() {
	log_err "$1"
	rollback_failed_start
	return 1
}

cmd_status() {
	jp_ipoe_config_load
	sh "$JP_IPOE_INFO_HELPER" status "$WAN6_IFACE" "$MAPE_IFACE" "$BR_ADDR"
}

cmd_detect_br() {
	jp_ipoe_config_load
	sh "$JP_IPOE_INFO_HELPER" detect_br "$WAN6_IFACE" "$LEGACYMAP"
}

# Main start command
cmd_start() {
	jp_ipoe_config_load

	log "Starting JP IPoE setup (OCN MAP-E)..."
	log "WAN device: $WAN_DEVICE, WAN6: $WAN6_IFACE, MAP-E: $MAPE_IFACE"
	jp_ipoe_state_snapshot_session_metadata "$WAN6_IFACE" "$MAPE_IFACE"

	# Step 1: Install patched map.sh
	install_map_sh || {
		fail_start "map.sh installation failed."
		return 1
	}

	# Step 2: Always converge WAN6 onto the required DHCPv6 settings.
	ensure_wan_device_ipv6 "$WAN_DEVICE" || {
		fail_start "WAN device IPv6 setup failed."
		return 1
	}

	setup_wan6 "$WAN_DEVICE" "$WAN6_IFACE" "" || {
		fail_start "WAN6 interface setup failed."
		return 1
	}

	# Always ensure WAN6 is up before we wait for its IP
	ifup "$WAN6_IFACE" 2>/dev/null || true
	sleep 3

	# Step 3: Wait for WAN6 to get an IPv6 address
	local wan6_dev
	wan6_dev=$(uci -q get network."$WAN6_IFACE".device 2>/dev/null)
	[ -z "$wan6_dev" ] && wan6_dev="$WAN_DEVICE"

	local ipv6_addr
	ipv6_addr=$(wait_for_ipv6 "$wan6_dev" 60)
	if [ $? -ne 0 ]; then
		fail_start "WAN6 did not get an IPv6 address."
		return 1
	fi

	# Step 4: Seed wan6 with a /64 ip6prefix only when MAP-E depends on it.
	# Pure auto-PD setups keep the delegated prefix untouched.
	ensure_wan6_ip6prefix "$WAN6_IFACE" "$wan6_dev" || {
		fail_start "Failed to prepare WAN6 ip6prefix for MAP-E startup."
		return 1
	}

	# Step 5: Setup MAP-E interface
	setup_mape "$MAPE_IFACE" "$WAN6_IFACE" "$BR_ADDR" "$LEGACYMAP"
	if [ $? -ne 0 ]; then
		fail_start "MAP-E interface setup failed."
		return 1
	fi

	# Step 6: Configure firewall and DHCPv6 relay
	setup_firewall "$WAN6_IFACE" "$MAPE_IFACE"
	if [ $? -ne 0 ]; then
		fail_start "Firewall zone setup failed."
		return 1
	fi

	setup_pppoe_fallback_metrics || {
		fail_start "PPPoE fallback metric setup failed."
		return 1
	}
	
	if [ "$DHCPV6_RELAY" = "1" ]; then
		configure_dhcpv6_relay "$WAN6_IFACE" 1 || {
			fail_start "DHCPv6 relay setup failed."
			return 1
		}
	else
		configure_dhcpv6_relay "$WAN6_IFACE" 0 || {
			fail_start "DHCPv6 relay disable failed."
			return 1
		}
	fi

	# Step 7: Bring up MAP-E interface to apply patched script, then reload firewall
	log "Bringing up MAP-E interface..."
	ifdown "$MAPE_IFACE" 2>/dev/null || true
	sleep 1
	ifup "$MAPE_IFACE" 2>/dev/null || true

	log "Reloading firewall..."
	fw4 reload 2>/dev/null || true

	log "JP IPoE setup complete!"
	return 0
}

# Stop / teardown
cmd_stop() {
	jp_ipoe_config_load
	resolve_restore_targets

	log "Stopping JP IPoE interfaces..."
	ifdown "$RESTORE_MAPE_IFACE" 2>/dev/null || true
	ifdown "$RESTORE_WAN6_IFACE" 2>/dev/null || true
	restore_network_config "$RESTORE_WAN6_IFACE" "$RESTORE_MAPE_IFACE" "$WAN_DEVICE"
	restore_pppoe_fallback_metrics
	restore_dhcp_config "$RESTORE_WAN6_IFACE"
	restore_firewall_config
	restore_map_sh
	jp_ipoe_state_clear
	log "Done."
}

# Entry point
case "$1" in
	start)   cmd_start ;;
	stop)    cmd_stop ;;
	status)  cmd_status ;;
	detect_br) cmd_detect_br ;;
	*)
		echo "Usage: $0 {start|stop|status|detect_br}"
		exit 1
		;;
esac
