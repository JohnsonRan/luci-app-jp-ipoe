#!/bin/sh
#
# jp-ipoe-setup - OCN Virtual Connect (MAP-E) auto-configuration script
# For OpenWrt 22.03+ (fw4/nftables)
#
# Usage:
#   jp-ipoe-setup start   - Configure IPoE interfaces
#   jp-ipoe-setup stop    - Remove IPoE interfaces
#   jp-ipoe-setup boot    - Run boot-time IPoE startup recovery
#   jp-ipoe-setup status  - Print current status as JSON
#   jp-ipoe-setup detect_br - Attempt to detect BR address
#

. /lib/functions.sh
. /lib/functions/network.sh
. /usr/share/jp-ipoe/config.sh

LOG_TAG="jp-ipoe"
LOCK_FILE="/var/lock/jp-ipoe.lock"
LOCK_WAIT_TIMEOUT="60"
PPPOE_FALLBACK_METRIC="200"
MAPE_MTU="1460"
JP_IPOE_INFO_HELPER="/usr/libexec/jp-ipoe-info"
WAN6_INITIAL_WAIT_TIMEOUT="20"
WAN6_RECOVERY_WAIT_TIMEOUT="30"
WAN6_IPV6_POLL_INTERVAL="2"
IFACE_DOWN_WAIT_TIMEOUT="4"
IFACE_STATE_POLL_INTERVAL="1"

log() {
	logger -t "$LOG_TAG" "$@"
	echo "$@" >&2
}

log_err() {
	logger -t "$LOG_TAG" -p daemon.err "$@"
	echo "ERROR: $@" >&2
}

FIREWALL_ZONE_MATCH=""
PPPOE_SECTION_MATCHES=""
NETWORK_DEVICE_MATCH=""
JP_IPOE_STOPPED_PPPOE=""

firewall_zone_find_by_name_cb() {
	local section="$1"
	local target_name="$2"
	local section_name

	[ -n "$FIREWALL_ZONE_MATCH" ] && return 0
	config_get section_name "$section" name ""
	[ "$section_name" = "$target_name" ] && FIREWALL_ZONE_MATCH="$section"
}

firewall_zone_find_by_network_cb() {
	local section="$1"
	local target_network="$2"
	local networks

	[ -n "$FIREWALL_ZONE_MATCH" ] && return 0
	config_get networks "$section" network ""
	list_contains networks "$target_network" && FIREWALL_ZONE_MATCH="$section"
}

find_firewall_zone() {
	local target_name="${1:-wan}"
	local primary_network="$2"
	local secondary_network="$3"

	config_load firewall

	FIREWALL_ZONE_MATCH=""
	config_foreach firewall_zone_find_by_name_cb zone "$target_name"
	[ -n "$FIREWALL_ZONE_MATCH" ] && {
		printf '%s' "$FIREWALL_ZONE_MATCH"
		return 0
	}

	if [ -n "$primary_network" ]; then
		FIREWALL_ZONE_MATCH=""
		config_foreach firewall_zone_find_by_network_cb zone "$primary_network"
		[ -n "$FIREWALL_ZONE_MATCH" ] && {
			printf '%s' "$FIREWALL_ZONE_MATCH"
			return 0
		}
	fi

	if [ -n "$secondary_network" ]; then
		FIREWALL_ZONE_MATCH=""
		config_foreach firewall_zone_find_by_network_cb zone "$secondary_network"
		[ -n "$FIREWALL_ZONE_MATCH" ] && {
			printf '%s' "$FIREWALL_ZONE_MATCH"
			return 0
		}
	fi

	return 1
}

get_firewall_zone_networks() {
	local zone="$1"
	local networks

	config_load firewall
	config_get networks "$zone" network ""
	printf '%s' "$networks"
}

pppoe_section_collect_cb() {
	local section="$1"
	local proto

	config_get proto "$section" proto ""
	[ "$proto" = "pppoe" ] || return 0
	append PPPOE_SECTION_MATCHES "$section"
}

find_pppoe_sections() {
	config_load network
	PPPOE_SECTION_MATCHES=""
	config_foreach pppoe_section_collect_cb interface
	printf '%s' "$PPPOE_SECTION_MATCHES"
}

find_wan_pppoe_sections() {
	local sections
	local section
	local wan_zone
	local wan_zone_networks
	local matches=""

	sections="$(find_pppoe_sections)"
	[ -n "$sections" ] || return 0

	wan_zone="$(find_firewall_zone "wan" "$WAN6_IFACE" "wan")"
	[ -n "$wan_zone" ] && wan_zone_networks="$(get_firewall_zone_networks "$wan_zone")"

	for section in $sections; do
		case "$section" in
			wan|pppoe-wan)
				append matches "$section"
				continue
				;;
		esac

		[ -n "$wan_zone_networks" ] || continue
		list_contains wan_zone_networks "$section" || continue
		append matches "$section"
	done

	printf '%s' "$matches"
}

network_device_find_by_name_cb() {
	local section="$1"
	local target_name="$2"
	local name

	[ -n "$NETWORK_DEVICE_MATCH" ] && return 0
	config_get name "$section" name ""
	[ "$name" = "$target_name" ] && NETWORK_DEVICE_MATCH="$section"
}

find_network_device_section() {
	local target_name="$1"

	[ -n "$target_name" ] || return 1
	config_load network

	NETWORK_DEVICE_MATCH=""
	config_foreach network_device_find_by_name_cb device "$target_name"
	[ -n "$NETWORK_DEVICE_MATCH" ] || return 1

	printf '%s' "$NETWORK_DEVICE_MATCH"
}

jp_ipoe_uci_set_or_delete_option() {
	local package="$1"
	local section="$2"
	local option="$3"
	local value="$4"

	if [ -n "$value" ]; then
		uci set "$package.$section.$option=$value"
	else
		uci delete "$package.$section.$option" 2>/dev/null || true
	fi
}

# Wait for WAN6 to get an IPv6 address (with timeout)
wait_for_ipv6() {
	local iface="$1"
	local timeout="${2:-60}"
	local elapsed=0
	local ip6

	log "Waiting for IPv6 address on $iface (timeout ${timeout}s)..."
	while [ $elapsed -lt $timeout ]; do
		network_flush_cache
		if network_get_subnet6 ip6 "$iface" && [ -n "$ip6" ]; then
			log "Got IPv6 address: $ip6"
			echo "$ip6"
			return 0
		fi
		sleep "$WAN6_IPV6_POLL_INTERVAL"
		elapsed=$((elapsed + WAN6_IPV6_POLL_INTERVAL))
	done
	log_err "Timeout waiting for IPv6 address on $iface"
	return 1
}

wait_for_interface_down() {
	local iface="$1"
	local timeout="${2:-$IFACE_DOWN_WAIT_TIMEOUT}"
	local elapsed=0

	[ -n "$iface" ] || return 0

	while [ $elapsed -lt $timeout ]; do
		network_flush_cache
		network_is_up "$iface" || return 0
		sleep "$IFACE_STATE_POLL_INTERVAL"
		elapsed=$((elapsed + IFACE_STATE_POLL_INTERVAL))
	done

	log "Interface $iface did not report down within ${timeout}s; continuing."
	return 1
}

# Get IPv6 prefix from WAN6 interface
get_ipv6_prefix() {
	local iface="$1"
	local device="$2"
	local p64
	local ip6

	# Prefer the kernel-installed connected /64 route instead of slicing text out of
	# a possibly compressed IPv6 address representation.
	if [ -n "$device" ]; then
		p64=$(ip -6 route show dev "$device" proto kernel 2>/dev/null | \
			awk '$1 ~ /\/64$/ && $1 !~ /^fe80:/ { print $1; exit }')
		if [ -n "$p64" ]; then
			log "IPv6 /64 prefix from kernel route: $p64"
			echo "$p64"
			return 0
		fi
	fi

	network_flush_cache
	network_get_subnet6 ip6 "$iface" || ip6=""
	if [ -z "$ip6" ] && [ -n "$device" ]; then
		ip6=$(ip -6 addr show dev "$device" scope global 2>/dev/null | \
			awk '/inet6/ && !/::1/ {print $2; exit}')
	fi
	if [ -z "$ip6" ]; then
		log_err "No global IPv6 address found on $iface"
		return 1
	fi

	p64=$(printf '%s\n' "$ip6" | awk '
		{
			sub(/\/.*/, "", $0)
			if ($0 ~ /::/) {
				split($0, halves, "::")
				left_count = (halves[1] == "" ? 0 : split(halves[1], left, ":"))
				right_count = (halves[2] == "" ? 0 : split(halves[2], right, ":"))
				total = 0
				for (i = 1; i <= left_count; i++)
					parts[++total] = left[i]
				zeros = 8 - left_count - right_count
				for (i = 1; i <= zeros; i++)
					parts[++total] = "0"
				for (i = 1; i <= right_count; i++)
					parts[++total] = right[i]
			} else {
				total = split($0, parts, ":")
			}

			if (total < 4)
				exit 1

			printf "%s:%s:%s:%s::/64\n",
				(parts[1] == "" ? "0" : parts[1]),
				(parts[2] == "" ? "0" : parts[2]),
				(parts[3] == "" ? "0" : parts[3]),
				(parts[4] == "" ? "0" : parts[4])
		}')
	if [ -z "$p64" ]; then
		log_err "Failed to calculate IPv6 /64 prefix from $ip6"
		return 1
	fi

	log "IPv6 /64 prefix from address fallback: $p64"
	echo "$p64"
	return 0
}

ensure_wan_device_ipv6() {
	local device="$1"
	local section

	section="$(find_network_device_section "$device")" || {
		log "No explicit network device section found for $device; leaving device IPv6 setting unchanged."
		return 0
	}

	uci set network."$section".ipv6="1"
	log "Enabled IPv6 on device $device."
}

normalize_hex_id() {
	printf '%s' "$1" | tr 'A-F' 'a-f' | tr -d ':-'
}

get_device_mac() {
	local device="$1"
	local mac

	[ -n "$device" ] || return 1
	[ -r "/sys/class/net/$device/address" ] || return 1

	read -r mac < "/sys/class/net/$device/address" || return 1
	mac="$(normalize_hex_id "$mac")"

	case "$mac" in
		????????????)
			case "$mac" in
				*[!0-9a-f]*) return 1 ;;
			esac
			printf '%s' "$mac"
			return 0
			;;
	esac

	return 1
}

ensure_wan6_duid_ll() {
	local iface="$1"
	local device="$2"
	local mac
	local expected_duid
	local current_duid
	local global_duid
	local normalized_current
	local normalized_global

	mac="$(get_device_mac "$device")" || {
		log_err "Unable to read MAC address for WAN device $device; cannot generate DHCPv6 DUID-LL."
		return 1
	}

	expected_duid="00030001$mac"
	current_duid="$(uci -q get network."$iface".clientid 2>/dev/null)"
	global_duid="$(uci -q get network.globals.dhcp_default_duid 2>/dev/null)"
	normalized_current="$(normalize_hex_id "$current_duid")"
	normalized_global="$(normalize_hex_id "$global_duid")"

	if [ "$normalized_current" = "$expected_duid" ]; then
		log "$iface DHCPv6 client ID already uses DUID-LL for $device."
		return 0
	fi

	if [ -z "$normalized_current" ] && [ "$normalized_global" = "$expected_duid" ]; then
		log "Global DHCPv6 default DUID already uses DUID-LL for $device."
		return 0
	fi

	log "Setting $iface DHCPv6 client ID to DUID-LL for $device."
	uci set network."$iface".clientid="$expected_duid"
}

# MAP-E still needs wan6.ip6prefix when relay mode is enabled or when the
# tunnel is being driven by manual MAP bounds / BR settings.
wan6_ip6prefix_required() {
	[ "$DHCPV6_RELAY" = "1" ] && return 0
	[ -n "$IPADDR" ] && return 0
	[ -n "$IP6PREFIX" ] && return 0
	[ -n "$BR_ADDR" ] && return 0
	return 1
}

ensure_wan6_ip6prefix() {
	local wan6_iface="$1"
	local wan6_dev="$2"
	local ip6prefix
	local current_prefix

	if ! wan6_ip6prefix_required; then
		log "Leaving $wan6_iface ip6prefix unchanged; MAP-E is using automatic PD matching."
		return 0
	fi

	ip6prefix=$(get_ipv6_prefix "$wan6_iface" "$wan6_dev") || return 1
	[ -n "$ip6prefix" ] || return 1

	current_prefix=$(uci -q get network."$wan6_iface".ip6prefix 2>/dev/null)
	if [ "$current_prefix" = "$ip6prefix" ]; then
		log "$wan6_iface ip6prefix already set to $ip6prefix"
		return 0
	fi

	log "Setting $wan6_iface ip6prefix to $ip6prefix for MAP-E startup"
	uci set network."$wan6_iface".ip6prefix="$ip6prefix"
	uci commit network
	ifup "$wan6_iface" 2>/dev/null || true
	wait_for_ipv6 "$wan6_iface" "$WAN6_RECOVERY_WAIT_TIMEOUT" >/dev/null || return 1
}

# Configure WAN6 interface via UCI
setup_wan6() {
	local device="$1"
	local iface="$2"

	log "Configuring $iface (DHCPv6) on device $device..."

	if ! uci -q get network."$iface" >/dev/null 2>&1; then
		log_err "WAN6 interface $iface does not exist. Please create it before starting JP IPoE."
		return 1
	fi

	uci set network."$iface".device="$device"
	uci set network."$iface".proto=dhcpv6
	uci set network."$iface".reqaddress=try
	uci set network."$iface".reqprefix=auto
	uci set network."$iface".ip6assign='64'
	ensure_wan6_duid_ll "$iface" "$device" || return 1
	uci delete network."$iface".ip6prefix 2>/dev/null || true

	uci commit network
	log "WAN6 interface $iface configured"
}

resolve_br_addr() {
	local wan6_iface="$1"
	local br_addr="$2"
	local legacymap="$3"
	local rule_data

	if [ -n "$br_addr" ]; then
		printf '%s' "$br_addr"
		return 0
	fi

	log "BR address not set, trying to detect via mapcalc..."
	rule_data=$(LEGACY="$legacymap" mapcalc "$wan6_iface" "type=map-e" 2>/dev/null)
	if [ $? -eq 0 ] && [ -n "$rule_data" ]; then
		br_addr="$(jp_ipoe_mapcalc_lookup "$rule_data" BR)"
		if [ -n "$br_addr" ]; then
			log "Detected BR address: $br_addr"
			printf '%s' "$br_addr"
			return 0
		fi
	fi

	log_err "BR address is empty. OCN Virtual Connect requires manual parameters if PD DHCP is disabled."
	log_err "Please use the map-e calculator (http://ipv4.web.fc2.com/map-e.html) and fill in the BR Address and other parameters in LuCI."
	return 1
}

# Configure MAP-E interface via UCI
setup_mape() {
	local mape_iface="$1"
	local wan6_iface="$2"
	local br_addr="$3"
	local legacymap="$4"

	log "Configuring MAP-E interface $mape_iface..."

	br_addr="$(resolve_br_addr "$wan6_iface" "$br_addr" "$legacymap")" || return 1

	# Create/update MAP-E interface
	if ! uci -q get network."$mape_iface" >/dev/null 2>&1; then
		uci set network."$mape_iface"=interface
	fi

	uci set network."$mape_iface".proto=map
	uci set network."$mape_iface".maptype=map-e
	uci set network."$mape_iface".peeraddr="$br_addr"
	uci set network."$mape_iface".tunlink="$wan6_iface"
	uci set network."$mape_iface".encaplimit=ignore
	uci set network."$mape_iface".mtu="$MAPE_MTU"
	if [ "$legacymap" = "1" ]; then
		uci set network."$mape_iface".legacymap=1
	else
		uci delete network."$mape_iface".legacymap 2>/dev/null || true
	fi

	# Populate advanced manual MAP-E bounds if set
	jp_ipoe_uci_set_or_delete_option network "$mape_iface" ipaddr "$IPADDR"
	jp_ipoe_uci_set_or_delete_option network "$mape_iface" ip4prefixlen "$IP4PREFIXLEN"
	jp_ipoe_uci_set_or_delete_option network "$mape_iface" ip6prefix "$IP6PREFIX"
	jp_ipoe_uci_set_or_delete_option network "$mape_iface" ip6prefixlen "$IP6PREFIXLEN"
	jp_ipoe_uci_set_or_delete_option network "$mape_iface" ealen "$EALEN"
	jp_ipoe_uci_set_or_delete_option network "$mape_iface" psidlen "$PSIDLEN"
	jp_ipoe_uci_set_or_delete_option network "$mape_iface" offset "$OFFSET"

	uci commit network
	log "MAP-E interface $mape_iface configured with BR $br_addr and MTU $MAPE_MTU"
}

# Add interfaces to WAN firewall zone
setup_firewall() {
	local wan6_iface="$1"
	local mape_iface="$2"
	local wan_zone
	local networks
	local iface

	log "Configuring firewall zones..."

	wan_zone="$(find_firewall_zone "wan" "$wan6_iface" "wan")"

	if [ -z "$wan_zone" ]; then
		log_err "Could not find WAN firewall zone"
		return 1
	fi

	# Add wan6 and mape to WAN zone if not already there
	config_load firewall
	config_get networks "$wan_zone" network ""
	for iface in "$wan6_iface" "$mape_iface"; do
		if list_contains networks "$iface"; then
			log "$iface already in WAN firewall zone"
		else
			uci add_list firewall."$wan_zone".network="$iface"
			append networks "$iface"
			log "Added $iface to WAN firewall zone"
		fi
	done

	uci commit firewall
}

setup_pppoe_fallback_metrics() {
	local section
	local sections_to_update

	sections_to_update="$(find_wan_pppoe_sections)"
	[ -n "$sections_to_update" ] || return 0

	for section in $sections_to_update; do
		uci set network."$section".metric="$PPPOE_FALLBACK_METRIC"
		log "Set PPPoE fallback metric $PPPOE_FALLBACK_METRIC on $section"
	done

	uci commit network
}

stop_pppoe_fallback_interfaces() {
	local pppoe_sections="$1"
	local section
	local stopped_sections=""

	setup_pppoe_fallback_metrics

	for section in $pppoe_sections; do
		log "Stopping PPPoE fallback interface $section before WAN6 restart."
		ifdown "$section" 2>/dev/null || true
		wait_for_interface_down "$section" || true
		append stopped_sections "$section"
		list_contains JP_IPOE_STOPPED_PPPOE "$section" || append JP_IPOE_STOPPED_PPPOE "$section"
	done

	[ -n "$stopped_sections" ] || {
		log_err "No PPPoE fallback interface stopped."
		return 1
	}

	log "Stopped PPPoE fallback interface(s): $stopped_sections"
	return 0
}

start_pppoe_fallback_interfaces() {
	local pppoe_sections="$1"
	local section

	[ -n "$pppoe_sections" ] || return 0

	for section in $pppoe_sections; do
		log "Starting PPPoE fallback interface $section after JP IPoE startup."
		ifup "$section" 2>/dev/null || log_err "Failed to start PPPoE fallback interface $section."
	done
}

# Restart any PPPoE fallback interface this run stopped (e.g. during WAN6 IPv6
# recovery) so the line always regains a working IPv4 fallback, regardless of
# whether IPoE setup ultimately succeeded.
restore_stopped_pppoe_fallback() {
	[ -n "$JP_IPOE_STOPPED_PPPOE" ] || return 0

	log "Restoring previously stopped PPPoE fallback interface(s): $JP_IPOE_STOPPED_PPPOE"
	start_pppoe_fallback_interfaces "$JP_IPOE_STOPPED_PPPOE"
	JP_IPOE_STOPPED_PPPOE=""
}

restart_wan6_interface() {
	local wan6_iface="$1"

	[ -n "$wan6_iface" ] || {
		log_err "WAN6 interface name is not configured."
		return 1
	}

	log "Restarting $wan6_iface before JP IPoE startup."
	ifdown "$wan6_iface" 2>/dev/null || true
	wait_for_interface_down "$wan6_iface" || true
	ifup "$wan6_iface" 2>/dev/null || true
}

validate_map_protocol() {
	local our_map="/lib/netifd/proto/map.sh"
	local helper="/usr/libexec/jp-ipoe-map-nft"
	local info_helper="/usr/libexec/jp-ipoe-info"
	local installer="/usr/libexec/jp-ipoe-install-map"

	if [ ! -f "$helper" ]; then
		log_err "Required MAP-E nft helper not found at $helper"
		return 1
	fi

	if [ ! -f "$info_helper" ]; then
		log_err "Required info helper not found at $info_helper"
		return 1
	fi

	if ! grep -q "JP_IPOE_PATCH_VERSION=" "$our_map" 2>/dev/null; then
		log "Patched MAP-E protocol script is not installed at $our_map; installing it now."
		if [ ! -f "$installer" ]; then
			log_err "MAP-E protocol installer not found at $installer"
			return 1
		fi
		sh "$installer" || {
			log_err "Failed to install patched MAP-E protocol script."
			return 1
		}
	fi

	log "Patched MAP-E protocol script is installed."
}

# Configure DHCPv6 / Router Advertisement Relay
configure_dhcpv6_relay() {
	local wan6_iface="$1"
	local enabled="$2"

	if [ "$enabled" = "1" ]; then
		log "Configuring DHCPv6 / RA Relay for $wan6_iface and lan..."
	else
		log "DHCPv6 Relay disabled, restoring standard server mode for lan..."
	fi

	# Ensure dhcp.wan6 exists
	if ! uci -q get dhcp."$wan6_iface" >/dev/null 2>&1; then
		uci set dhcp."$wan6_iface"=dhcp
		uci set dhcp."$wan6_iface".interface="$wan6_iface"
	fi

	if [ "$enabled" = "1" ]; then
		uci set dhcp."$wan6_iface".master="1"
		uci set dhcp."$wan6_iface".ra="relay"
		uci set dhcp."$wan6_iface".dhcpv6="relay"
		uci set dhcp."$wan6_iface".ndp="relay"
		uci set dhcp."$wan6_iface".ndproxy_routing="1"
	else
		uci delete dhcp."$wan6_iface".master 2>/dev/null
		uci set dhcp."$wan6_iface".ra="disabled"
		uci set dhcp."$wan6_iface".dhcpv6="disabled"
		uci set dhcp."$wan6_iface".ndp="disabled"
		uci delete dhcp."$wan6_iface".ndproxy_routing 2>/dev/null
	fi

	if uci -q get dhcp.lan >/dev/null 2>&1; then
		if [ "$enabled" = "1" ]; then
			uci delete dhcp.lan.master 2>/dev/null
			uci set dhcp.lan.ra="relay"
			uci set dhcp.lan.dhcpv6="relay"
			uci set dhcp.lan.ndp="relay"
		else
			uci set dhcp.lan.ra="server"
			uci set dhcp.lan.dhcpv6="server"
			uci delete dhcp.lan.ndp 2>/dev/null
		fi
	fi

	uci commit dhcp
	/etc/init.d/odhcpd restart 2>/dev/null || true
	[ "$enabled" = "1" ] && log "DHCPv6 Relay configured successfully."
}

recover_wan6_after_pppoe_conflict() {
	local wan6_iface="$1"
	local pppoe_sections

	pppoe_sections="$(find_wan_pppoe_sections)"
	[ -n "$pppoe_sections" ] || {
		log "WAN6 recovery skipped; no WAN PPPoE fallback interface found."
		return 1
	}

	log "WAN6 did not get IPv6. Resetting managed IPoE state before PPPoE fallback stop."
	teardown_managed_ipoe

	stop_pppoe_fallback_interfaces "$pppoe_sections" || return 1

	log "Restarting $wan6_iface after PPPoE fallback stopped."
	ifup "$wan6_iface" 2>/dev/null || true

	wait_for_ipv6 "$wan6_iface" "$WAN6_RECOVERY_WAIT_TIMEOUT" >/dev/null || {
		log_err "WAN6 recovery failed after stopping PPPoE fallback."
		return 1
	}

	log "WAN6 recovered after stopping PPPoE fallback."
}

stop_managed_interfaces() {
	ifdown "$MAPE_IFACE" 2>/dev/null || true
}

remove_firewall_network() {
	local mape_iface="$1"
	local wan_zone

	wan_zone="$(find_firewall_zone "wan" "$WAN6_IFACE" "$mape_iface")" || return 0
	uci del_list firewall."$wan_zone".network="$mape_iface" 2>/dev/null || true
	uci commit firewall
	fw4 reload 2>/dev/null || true
	log "Removed $mape_iface from WAN firewall zone."
}

remove_mape_config() {
	local mape_iface="$1"
	local proto
	local tunlink

	proto="$(uci -q get network."$mape_iface".proto 2>/dev/null)"
	tunlink="$(uci -q get network."$mape_iface".tunlink 2>/dev/null)"

	if [ "$proto" = "map" ] && { [ -z "$tunlink" ] || [ "$tunlink" = "$WAN6_IFACE" ]; }; then
		uci delete network."$mape_iface" 2>/dev/null || true
		uci commit network
		log "Removed MAP-E interface $mape_iface."
	else
		log "Leaving network.$mape_iface unchanged; it does not look like the managed MAP-E interface."
	fi
}

remove_managed_config() {
	remove_firewall_network "$MAPE_IFACE"
	remove_mape_config "$MAPE_IFACE"
}

# setup_wan6 / ensure_wan6_ip6prefix fully own network.<wan6>.ip6prefix (it is
# re-derived on every start), so clear it on teardown to avoid leaving a stale
# managed prefix behind after a failed start or a stop.
remove_managed_wan6_state() {
	[ -n "$WAN6_IFACE" ] || return 0

	if uci -q get network."$WAN6_IFACE".ip6prefix >/dev/null 2>&1; then
		uci delete network."$WAN6_IFACE".ip6prefix 2>/dev/null || true
		uci commit network
		log "Cleared managed ip6prefix on $WAN6_IFACE."
	fi
}

teardown_managed_ipoe() {
	stop_managed_interfaces
	remove_managed_config
	remove_managed_wan6_state
}

rollback_failed_start() {
	log_err "Start failed, removing managed MAP-E configuration."
	teardown_managed_ipoe
}

fail_start() {
	log_err "$1"
	rollback_failed_start
	return 1
}

validate_config() {
	[ -n "$WAN_DEVICE" ] || {
		log_err "WAN physical device is not configured."
		return 1
	}

	[ -n "$WAN6_IFACE" ] || {
		log_err "WAN6 interface name is not configured."
		return 1
	}

	if ! uci -q get network."$WAN6_IFACE" >/dev/null 2>&1; then
		log_err "WAN6 interface $WAN6_IFACE does not exist. Please create it before starting JP IPoE."
		return 1
	fi

	[ -n "$MAPE_IFACE" ] || {
		log_err "MAP-E interface name is not configured."
		return 1
	}

	if [ "$MAPE_IFACE" = "$WAN6_IFACE" ]; then
		log_err "MAP-E interface name ($MAPE_IFACE) must differ from the WAN6 interface; refusing to overwrite WAN6."
		return 1
	fi
}

apply_map_protocol() {
	validate_map_protocol
}

apply_network_config() {
	local wan6_dev

	ensure_wan_device_ipv6 "$WAN_DEVICE" || return 1
	setup_wan6 "$WAN_DEVICE" "$WAN6_IFACE" || return 1

	ifup "$WAN6_IFACE" 2>/dev/null || true

	wait_for_ipv6 "$WAN6_IFACE" "$WAN6_INITIAL_WAIT_TIMEOUT" >/dev/null || {
		recover_wan6_after_pppoe_conflict "$WAN6_IFACE" || return 1
	}

	network_flush_cache
	network_get_device wan6_dev "$WAN6_IFACE" || wan6_dev="$(uci -q get network."$WAN6_IFACE".device 2>/dev/null)"
	[ -z "$wan6_dev" ] && wan6_dev="$WAN_DEVICE"

	ensure_wan6_ip6prefix "$WAN6_IFACE" "$wan6_dev" || return 1
	setup_mape "$MAPE_IFACE" "$WAN6_IFACE" "$BR_ADDR" "$LEGACYMAP"
}

apply_firewall_config() {
	setup_firewall "$WAN6_IFACE" "$MAPE_IFACE" || return 1
	setup_pppoe_fallback_metrics
}

apply_dhcp_config() {
	if [ "$DHCPV6_RELAY" = "1" ]; then
		configure_dhcpv6_relay "$WAN6_IFACE" 1
	else
		configure_dhcpv6_relay "$WAN6_IFACE" 0
	fi
}

bringup_mape() {
	log "Bringing up MAP-E interface..."
	ifup "$MAPE_IFACE" 2>/dev/null || true

	log "Reloading firewall..."
	fw4 reload 2>/dev/null || true
}

cmd_status() {
	jp_ipoe_config_load
	sh "$JP_IPOE_INFO_HELPER" status "$WAN6_IFACE" "$MAPE_IFACE" "$BR_ADDR"
}

cmd_detect_br() {
	jp_ipoe_config_load
	sh "$JP_IPOE_INFO_HELPER" detect_br "$WAN6_IFACE" "$LEGACYMAP"
}

run_start_pipeline() {
	validate_config || {
		log_err "Configuration validation failed."
		return 1
	}

	apply_map_protocol || {
		log_err "MAP-E protocol validation failed."
		return 1
	}

	apply_network_config || {
		fail_start "Network interface setup failed."
		return 1
	}

	apply_firewall_config || {
		fail_start "Firewall or PPPoE metric setup failed."
		return 1
	}

	apply_dhcp_config || {
		fail_start "DHCPv6 relay setup failed."
		return 1
	}

	bringup_mape
}

# Main start command
cmd_start() {
	local rc

	jp_ipoe_config_load

	log "Starting JP IPoE setup (OCN MAP-E)..."
	log "WAN device: $WAN_DEVICE, WAN6: $WAN6_IFACE, MAP-E: $MAPE_IFACE"

	run_start_pipeline
	rc=$?

	# Always restore PPPoE fallback interfaces stopped during this run, on both
	# success (they coexist as a lower-priority fallback) and failure (the line
	# keeps working IPv4 connectivity instead of losing it entirely).
	restore_stopped_pppoe_fallback

	[ $rc -eq 0 ] && log "JP IPoE setup complete!"
	return $rc
}

# Stop / teardown
cmd_stop() {
	jp_ipoe_config_load

	log "Stopping JP IPoE interfaces..."
	teardown_managed_ipoe
	log "Done."
}

cmd_boot() {
	local pppoe_sections

	cmd_stop

	pppoe_sections="$(find_wan_pppoe_sections)"
	if [ -n "$pppoe_sections" ]; then
		stop_pppoe_fallback_interfaces "$pppoe_sections" || true
	else
		log "No WAN PPPoE fallback interface found before WAN6 restart."
	fi

	restart_wan6_interface "$WAN6_IFACE" || true

	# cmd_start restores any PPPoE fallback we stopped above, whether IPoE
	# startup succeeds or fails, so the line never boots with no connectivity.
	cmd_start
}

# Serialize mutating operations so a LuCI apply, an SSH run, and the boot
# service cannot race each other's uci commits and interface bring-up.
# Read-only commands (status/detect_br, polled by LuCI) run without the lock.
run_locked() {
	command -v flock >/dev/null 2>&1 || { "$@"; return $?; }

	exec 9>"$LOCK_FILE" 2>/dev/null || { "$@"; return $?; }

	if ! flock -w "$LOCK_WAIT_TIMEOUT" 9; then
		log_err "Another jp-ipoe operation is already in progress; aborting."
		return 1
	fi

	"$@"
}

# Entry point
case "$1" in
	start)   run_locked cmd_start ;;
	stop)    run_locked cmd_stop ;;
	boot)    run_locked cmd_boot ;;
	status)  cmd_status ;;
	detect_br) cmd_detect_br ;;
	*)
		echo "Usage: $0 {start|stop|boot|status|detect_br}"
		exit 1
		;;
esac
